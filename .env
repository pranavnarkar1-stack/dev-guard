# GitHub Personal Access Token (needs repo scope: contents, pull_requests, statuses)
GITHUB_TOKEN=your_github_personal_access_token_here

# Optional: GitHub webhook secret (set this same value in your GitHub webhook settings)
GITHUB_WEBHOOK_SECRET=

# Ollama settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Server port
PORT=3000

# Max characters of diff sent to the model (keep small for speed on local hardware)
MAX_DIFF_CHARS=6000
